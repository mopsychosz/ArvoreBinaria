public class Main {

    public static void main(String[] args) {

        ArvoreBinaria arvoreBinaria = new ArvoreBinaria();

        arvoreBinaria.inserir(100); 
        arvoreBinaria.inserir(50);
        arvoreBinaria.inserir(150);
        arvoreBinaria.inserir(25);
        arvoreBinaria.inserir(75);
        arvoreBinaria.inserir(175);
        arvoreBinaria.inserir(125);
        arvoreBinaria.inserir(130);
        
        System.out.println("\narvore: ");

        System.out.println("\nremovendo no folha: 25");
        arvoreBinaria.remover(25);

        System.out.println("\nremovendo no com 1 filho: 125");
        arvoreBinaria.remover(125); 

        System.out.println("\nremovendo no com 2 filhos: 100");
        arvoreBinaria.remover(100); 
    }
}
